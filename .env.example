# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Lovable.dev session cookie (lovable-session-id-v2)
LOVABLE_SESSION_COOKIE=your_session_cookie_value_here

# Restrict access to specific Telegram User IDs (comma-separated)
# Get your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# (Optional) Public URL for webhook mode on HF Spaces
# Example: https://username-spacename.hf.space
WEBHOOK_URL=

# Port (default 7860 for Hugging Face Spaces)
PORT=7860

# Set to true to disable Telegram Bot polling and run only the Web UI dashboard
DISABLE_TELEGRAM=false
